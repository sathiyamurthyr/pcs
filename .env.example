# Example environment variables for production (do NOT commit secrets)
DB_HOST=your_production_db_host
DB_USER=your_db_user
DB_PASSWORD=CHANGE_ME
DB_NAME=pooja_db
JWT_SECRET=replace_with_secure_random_string
JWT_EXPIRE=7d
# Vercel sets PORT dynamically for serverless; for local testing you can keep 3000
PORT=3000
